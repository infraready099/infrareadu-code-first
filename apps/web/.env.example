# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# AWS (InfraReady's own account — for SQS)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
DEPLOY_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/YOUR_ACCOUNT/infraready-deploy.fifo

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# GitHub App (https://github.com/settings/apps)
# Create a GitHub App, then fill these in.
GITHUB_APP_ID=                          # Numeric App ID shown on the App settings page
GITHUB_APP_SLUG=infraready-deploy       # URL-friendly slug, e.g. "infraready-deploy"
GITHUB_APP_PRIVATE_KEY=                 # PEM private key — newlines as \n (or base64-encode it)
GITHUB_WEBHOOK_SECRET=                  # Random secret set in the App's webhook config

# App
NEXT_PUBLIC_APP_URL=https://infraready.io
